{
  "xsappname": "soc-hackathon-app",
  "tenant-mode": "dedicated",
  "description": "SAP SOC Hackathon Security Config",
  "scopes": [
    {
      "name": "$XSAPPNAME.view",
      "description": "View anomalies and incidents"
    },
    {
      "name": "$XSAPPNAME.admin",
      "description": "Full admin access"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "SOC Viewer role",
      "scope-references": ["$XSAPPNAME.view"]
    },
    {
      "name": "Admin",
      "description": "SOC Admin role",
      "scope-references": ["$XSAPPNAME.view", "$XSAPPNAME.admin"]
    }
  ]
}
